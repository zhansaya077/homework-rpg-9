package com.narxoz.rpg.artifact;

public class AppraisalVisitor
        implements ArtifactVisitor {

    @Override
    public void visit(Weapon weapon) {

        System.out.println(
                "Weapon: "
                        + weapon.getName()
                        + " | Damage: "
                        + weapon.getDamage()
        );
    }

    @Override
    public void visit(Potion potion) {

        System.out.println(
                "Potion: "
                        + potion.getName()
                        + " | Heal: "
                        + potion.getHealAmount()
        );
    }

    @Override
    public void visit(Scroll scroll) {

        System.out.println(
                "Scroll: "
                        + scroll.getName()
                        + " | Spell: "
                        + scroll.getSpell()
        );
    }

    @Override
    public void visit(Ring ring) {

        System.out.println(
                "Ring: "
                        + ring.getName()
                        + " | Effect: "
                        + ring.getEffect()
        );
    }

    @Override
    public void visit(Armor armor) {

        System.out.println(
                "Armor: "
                        + armor.getName()
                        + " | Defense: "
                        + armor.getDefense()
        );
    }
}
